# Copie para .env.local e preencha com os dados do seu projeto Supabase.
# (Settings → API no painel do Supabase)
#
# IMPORTANTE: aqui só vão valores PÚBLICOS (URL e chave anon/publishable).
# NUNCA coloque service_role key, senha do banco ou Google Client Secret —
# esses são segredos e ficam em Edge Functions / painel do Supabase.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica

# Domínio interno usado para login por CPF (CPF -> e-mail sintético).
VITE_CPF_EMAIL_DOMAIN=geny.local
